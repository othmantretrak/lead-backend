# ─── Database ─────────────────────────────────────────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Find these in hosting.com phpMyAdmin or cPanel → MySQL Databases
DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=verify-full"

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=3001

# Shared secret between Next.js frontend and this API
# Generate a random string: openssl rand -hex 32
API_KEY=""

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Your Vercel URL (update after deploying Next.js)
ALLOWED_ORIGIN="http://localhost:3000"

# ─── OAuth (Gmail) ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3001/auth/google/callback"

# ─── OAuth (Outlook / Microsoft) ─────────────────────────────────────────────
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_REDIRECT_URI="http://localhost:3001/auth/microsoft/callback"

# ─── Frontend URL (for OAuth popup redirect) ─────────────────────────────────
FRONTEND_URL="http://localhost:3000" 